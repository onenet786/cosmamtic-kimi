generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & BRANCH ====================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches       Branch[]
  users          User[]
  fiscalYears    FiscalYear[]
  accounts       Account[]
  parties        Party[]
  items          Item[]
  categories     Category[]
  brands         Brand[]
  warehouses     Warehouse[]
  vouchers       Voucher[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  priceLists     PriceList[]
  schemes        Scheme[]
  approvalChains ApprovalChain[]
  auditLogs      AuditLog[]
  UnitOfMeasure  UnitOfMeasure[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  users              User[]
  warehouses         Warehouse[]
  cashAccounts       Account[]
  vouchers           Voucher[]
  purchaseOrders     PurchaseOrder[]
  salesOrders        SalesOrder[]
  posSessions        POSSession[]
  stockTransfersFrom StockTransfer[] @relation("SourceBranch")
  stockTransfersTo   StockTransfer[] @relation("DestBranch")

  @@unique([tenantId, code])
  @@map("branches")
}

// ==================== USERS & RBAC ====================

model User {
  id           String    @id @default(cuid())
  tenantId     String
  branchId     String?
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  branch      Branch?          @relation(fields: [branchId], references: [id])
  vouchers    Voucher[]
  auditLogs   AuditLog[]
  approvals   ApprovalRecord[]
  posSessions POSSession[]

  @@map("users")
}

enum Role {
  OWNER
  PARTNER
  ACCOUNTANT
  BRANCH_MANAGER
  CASHIER
  WAREHOUSE_STAFF
  SALES_REP
}

// ==================== FINANCIAL: CHART OF ACCOUNTS ====================

model Account {
  id            String       @id @default(cuid())
  tenantId      String
  branchId      String?
  code          String
  name          String
  level         AccountLevel
  type          AccountType
  normalBalance DebitCredit
  isControl     Boolean      @default(false)
  isBank        Boolean      @default(false)
  isCash        Boolean      @default(false)
  parentId      String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  parent          Account?         @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]        @relation("AccountHierarchy")
  voucherLines    VoucherLine[]
  openingBalances OpeningBalance[]

  @@unique([tenantId, code])
  @@map("accounts")
}

enum AccountLevel {
  CLASS
  GROUP
  CATEGORY
  LEDGER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum DebitCredit {
  DEBIT
  CREDIT
}

model OpeningBalance {
  id           String  @id @default(cuid())
  tenantId     String
  accountId    String
  branchId     String?
  fiscalYearId String
  debit        Decimal @default(0) @db.Decimal(18, 4)
  credit       Decimal @default(0) @db.Decimal(18, 4)

  account    Account    @relation(fields: [accountId], references: [id])
  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@unique([tenantId, accountId, branchId, fiscalYearId])
  @@map("opening_balances")
}

model FiscalYear {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  vouchers        Voucher[]
  openingBalances OpeningBalance[]

  @@unique([tenantId, name])
  @@map("fiscal_years")
}

// ==================== VOUCHERS ====================

model Voucher {
  id            String        @id @default(cuid())
  tenantId      String
  branchId      String
  fiscalYearId  String
  voucherType   VoucherType
  voucherNumber String
  voucherDate   DateTime
  reference     String?
  narration     String
  totalDebit    Decimal       @db.Decimal(18, 4)
  totalCredit   Decimal       @db.Decimal(18, 4)
  status        VoucherStatus @default(POSTED)
  isReversed    Boolean       @default(false)
  reversedById  String?
  reversedAt    DateTime?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  branch      Branch           @relation(fields: [branchId], references: [id])
  fiscalYear  FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  createdBy   User             @relation(fields: [createdById], references: [id])
  lines       VoucherLine[]
  approvals   ApprovalRecord[]
  attachments Attachment[]

  @@unique([tenantId, branchId, fiscalYearId, voucherType, voucherNumber])
  @@map("vouchers")
}

enum VoucherType {
  JOURNAL
  PAYMENT
  RECEIPT
  CONTRA
  DEBIT_NOTE
  CREDIT_NOTE
}

enum VoucherStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REVERSED
  CANCELLED
}

model VoucherLine {
  id         String  @id @default(cuid())
  voucherId  String
  accountId  String
  branchId   String?
  debit      Decimal @default(0) @db.Decimal(18, 4)
  credit     Decimal @default(0) @db.Decimal(18, 4)
  narration  String?
  costCenter String?
  partyId    String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])
  party   Party?  @relation(fields: [partyId], references: [id])

  @@map("voucher_lines")
}

// ==================== PARTY MASTER ====================

model Party {
  id                String      @id @default(cuid())
  tenantId          String
  code              String
  name              String
  type              PartyType
  subClass          PartyClass?
  phone             String?
  email             String?
  address           String?
  city              String?
  province          String?
  taxNumber         String?
  creditLimit       Decimal?    @db.Decimal(18, 4)
  creditDays        Int?
  creditEnforcement CreditMode  @default(WARN)
  priceListId       String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  priceList      PriceList?      @relation(fields: [priceListId], references: [id])
  voucherLines   VoucherLine[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  payments       Payment[]
  receipts       Receipt[]
  pdcs           PDCCheque[]

  @@unique([tenantId, code])
  @@map("parties")
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum PartyClass {
  RETAILER
  WHOLESALER
  DISTRIBUTOR
  SALON
}

enum CreditMode {
  WARN
  BLOCK
  NONE
}

// ==================== INVENTORY ====================

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  items    Item[]

  @@unique([tenantId, name])
  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  items  Item[]

  @@unique([tenantId, name])
  @@map("brands")
}

model Item {
  id              String   @id @default(cuid())
  tenantId        String
  code            String
  name            String
  description     String?
  categoryId      String?
  brandId         String?
  baseUnitId      String
  purchaseUnitId  String?
  salesUnitId     String?
  reportingUnitId String?
  hsCode          String?
  taxCategoryId   String?
  isBatchTracked  Boolean  @default(false)
  isActive        Boolean  @default(true)
  isParent        Boolean  @default(false)
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  brand              Brand?              @relation(fields: [brandId], references: [id])
  baseUnit           UnitOfMeasure       @relation("BaseUnit", fields: [baseUnitId], references: [id])
  purchaseUnit       UnitOfMeasure?      @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id])
  salesUnit          UnitOfMeasure?      @relation("SalesUnit", fields: [salesUnitId], references: [id])
  reportingUnit      UnitOfMeasure?      @relation("ReportingUnit", fields: [reportingUnitId], references: [id])
  parent             Item?               @relation("ItemVariant", fields: [parentId], references: [id])
  variants           Item[]              @relation("ItemVariant")
  barcodes           Barcode[]
  uomConversions     ItemUOMConversion[]
  stockLedger        StockLedgerEntry[]
  priceListItems     PriceListItem[]
  purchaseOrderLines PurchaseOrderLine[]
  salesOrderLines    SalesOrderLine[]

  @@unique([tenantId, code])
  @@map("items")
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // e.g., Piece, Dozen, Carton
  symbol    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  baseUnitItems      Item[]              @relation("BaseUnit")
  purchaseUnitItems  Item[]              @relation("PurchaseUnit")
  salesUnitItems     Item[]              @relation("SalesUnit")
  reportingUnitItems Item[]              @relation("ReportingUnit")
  conversionsFrom    ItemUOMConversion[] @relation("ConversionFrom")
  conversionsTo      ItemUOMConversion[] @relation("ConversionTo")
  Barcode            Barcode[]

  @@unique([tenantId, name])
  @@map("units_of_measure")
}

model ItemUOMConversion {
  id               String  @id @default(cuid())
  itemId           String
  fromUnitId       String
  toUnitId         String
  conversionFactor Decimal @db.Decimal(18, 6) // quantity in toUnit per 1 fromUnit

  item     Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromUnit UnitOfMeasure @relation("ConversionFrom", fields: [fromUnitId], references: [id])
  toUnit   UnitOfMeasure @relation("ConversionTo", fields: [toUnitId], references: [id])

  @@unique([itemId, fromUnitId, toUnitId])
  @@map("item_uom_conversions")
}

model Barcode {
  id        String  @id @default(cuid())
  tenantId  String
  itemId    String
  variantId String?
  unitId    String
  barcode   String
  isActive  Boolean @default(true)

  item Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unit UnitOfMeasure @relation(fields: [unitId], references: [id])

  @@unique([tenantId, barcode])
  @@map("barcodes")
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  branch        Branch?            @relation(fields: [branchId], references: [id])
  stockLedger   StockLedgerEntry[]
  transfersFrom StockTransfer[]    @relation("SourceWarehouse")
  transfersTo   StockTransfer[]    @relation("DestWarehouse")
  adjustments   StockAdjustment[]
  counts        PhysicalCount[]

  @@unique([tenantId, code])
  @@map("warehouses")
}

model StockLedgerEntry {
  id              String             @id @default(cuid())
  tenantId        String
  itemId          String
  warehouseId     String
  batchId         String?
  quantity        Decimal            @db.Decimal(18, 6)
  unitCost        Decimal            @db.Decimal(18, 6)
  totalCost       Decimal            @db.Decimal(18, 4)
  referenceType   StockReferenceType
  referenceId     String
  referenceLineId String?
  transactionDate DateTime
  createdAt       DateTime           @default(now())

  item      Item        @relation(fields: [itemId], references: [id])
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  batch     StockBatch? @relation(fields: [batchId], references: [id])

  @@map("stock_ledger_entries")
}

enum StockReferenceType {
  PURCHASE_GRN
  PURCHASE_RETURN
  SALES_INVOICE
  SALES_RETURN
  STOCK_TRANSFER_IN
  STOCK_TRANSFER_OUT
  STOCK_ADJUSTMENT
  OPENING_BALANCE
  PHYSICAL_COUNT
}

model StockBatch {
  id          String    @id @default(cuid())
  tenantId    String
  itemId      String
  warehouseId String
  batchNumber String
  expiryDate  DateTime?
  quantity    Decimal   @db.Decimal(18, 6)
  unitCost    Decimal   @db.Decimal(18, 6)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ledgerEntries StockLedgerEntry[]

  @@unique([tenantId, itemId, warehouseId, batchNumber])
  @@map("stock_batches")
}

model StockTransfer {
  id                String         @id @default(cuid())
  tenantId          String
  sourceBranchId    String
  destBranchId      String
  sourceWarehouseId String
  destWarehouseId   String
  status            TransferStatus @default(DRAFT)
  transferDate      DateTime
  createdById       String
  approvedById      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sourceBranch    Branch              @relation("SourceBranch", fields: [sourceBranchId], references: [id])
  destBranch      Branch              @relation("DestBranch", fields: [destBranchId], references: [id])
  sourceWarehouse Warehouse           @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destWarehouse   Warehouse           @relation("DestWarehouse", fields: [destWarehouseId], references: [id])
  lines           StockTransferLine[]

  @@map("stock_transfers")
}

enum TransferStatus {
  DRAFT
  PENDING_APPROVAL
  DISPATCHED
  RECEIVED
  CANCELLED
}

model StockTransferLine {
  id         String  @id @default(cuid())
  transferId String
  itemId     String
  batchId    String?
  quantity   Decimal @db.Decimal(18, 6)
  unitCost   Decimal @db.Decimal(18, 6)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_lines")
}

model StockAdjustment {
  id             String           @id @default(cuid())
  tenantId       String
  warehouseId    String
  reasonCode     String
  adjustmentDate DateTime
  status         AdjustmentStatus @default(DRAFT)
  createdById    String
  approvedById   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  warehouse Warehouse             @relation(fields: [warehouseId], references: [id])
  lines     StockAdjustmentLine[]

  @@map("stock_adjustments")
}

enum AdjustmentStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  CANCELLED
}

model StockAdjustmentLine {
  id           String  @id @default(cuid())
  adjustmentId String
  itemId       String
  batchId      String?
  quantity     Decimal @db.Decimal(18, 6)
  unitCost     Decimal @db.Decimal(18, 6)

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@map("stock_adjustment_lines")
}

model PhysicalCount {
  id           String      @id @default(cuid())
  tenantId     String
  warehouseId  String
  countDate    DateTime
  status       CountStatus @default(DRAFT)
  createdById  String
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  lines     PhysicalCountLine[]

  @@map("physical_counts")
}

enum CountStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  CANCELLED
}

model PhysicalCountLine {
  id          String  @id @default(cuid())
  countId     String
  itemId      String
  batchId     String?
  systemQty   Decimal @db.Decimal(18, 6)
  countedQty  Decimal @db.Decimal(18, 6)
  varianceQty Decimal @db.Decimal(18, 6)

  count PhysicalCount @relation(fields: [countId], references: [id], onDelete: Cascade)

  @@map("physical_count_lines")
}

// ==================== PURCHASE & SALES ====================

model PurchaseOrder {
  id           String         @id @default(cuid())
  tenantId     String
  branchId     String
  supplierId   String
  orderNumber  String
  orderDate    DateTime
  expectedDate DateTime?
  status       PurchaseStatus @default(DRAFT)
  totalAmount  Decimal        @db.Decimal(18, 4)
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  branch   Branch              @relation(fields: [branchId], references: [id])
  supplier Party               @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]
  grns     GoodsReceivedNote[]
  invoices PurchaseInvoice[]

  @@unique([tenantId, branchId, orderNumber])
  @@map("purchase_orders")
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  itemId          String
  unitId          String
  quantity        Decimal @db.Decimal(18, 6)
  receivedQty     Decimal @default(0) @db.Decimal(18, 6)
  unitPrice       Decimal @db.Decimal(18, 6)
  discountPercent Decimal @default(0) @db.Decimal(18, 4)
  taxPercent      Decimal @default(0) @db.Decimal(18, 4)
  lineTotal       Decimal @db.Decimal(18, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])

  @@map("purchase_order_lines")
}

model GoodsReceivedNote {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String
  purchaseOrderId String
  grnNumber       String
  grnDate         DateTime
  status          GRNStatus @default(OPEN)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrder   PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  lines           GRNLine[]
  PurchaseInvoice PurchaseInvoice[]

  @@unique([tenantId, branchId, grnNumber])
  @@map("goods_received_notes")
}

enum GRNStatus {
  OPEN
  INVOICED
  PARTIALLY_INVOICED
  CLOSED
  CANCELLED
}

model GRNLine {
  id        String  @id @default(cuid())
  grnId     String
  poLineId  String
  itemId    String
  batchId   String?
  quantity  Decimal @db.Decimal(18, 6)
  unitPrice Decimal @db.Decimal(18, 6)
  unitCost  Decimal @db.Decimal(18, 6)
  lineTotal Decimal @db.Decimal(18, 4)

  grn GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@map("grn_lines")
}

model PurchaseInvoice {
  id              String        @id @default(cuid())
  tenantId        String
  branchId        String
  purchaseOrderId String
  grnId           String
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime?
  totalAmount     Decimal       @db.Decimal(18, 4)
  totalTax        Decimal       @default(0) @db.Decimal(18, 4)
  status          InvoiceStatus @default(OPEN)
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  purchaseOrder PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  grn           GoodsReceivedNote @relation(fields: [grnId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@map("purchase_invoices")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model SalesOrder {
  id           String      @id @default(cuid())
  tenantId     String
  branchId     String
  customerId   String
  orderNumber  String
  orderDate    DateTime
  expectedDate DateTime?
  status       SalesStatus @default(DRAFT)
  totalAmount  Decimal     @db.Decimal(18, 4)
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  branch   Branch           @relation(fields: [branchId], references: [id])
  customer Party            @relation(fields: [customerId], references: [id])
  lines    SalesOrderLine[]
  invoices SalesInvoice[]

  @@unique([tenantId, branchId, orderNumber])
  @@map("sales_orders")
}

enum SalesStatus {
  DRAFT
  PENDING_APPROVAL
  CONFIRMED
  PARTIALLY_DELIVERED
  FULLY_DELIVERED
  CANCELLED
}

model SalesOrderLine {
  id              String  @id @default(cuid())
  salesOrderId    String
  itemId          String
  unitId          String
  quantity        Decimal @db.Decimal(18, 6)
  deliveredQty    Decimal @default(0) @db.Decimal(18, 6)
  unitPrice       Decimal @db.Decimal(18, 6)
  discountPercent Decimal @default(0) @db.Decimal(18, 4)
  taxPercent      Decimal @default(0) @db.Decimal(18, 4)
  lineTotal       Decimal @db.Decimal(18, 4)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@map("sales_order_lines")
}

model SalesInvoice {
  id            String        @id @default(cuid())
  tenantId      String
  branchId      String
  salesOrderId  String
  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?
  totalAmount   Decimal       @db.Decimal(18, 4)
  totalTax      Decimal       @default(0) @db.Decimal(18, 4)
  status        InvoiceStatus @default(OPEN)
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@map("sales_invoices")
}

// ==================== PAYMENTS & RECEIPTS ====================

model Payment {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  partyId       String
  accountId     String
  paymentNumber String
  paymentDate   DateTime
  amount        Decimal     @db.Decimal(18, 4)
  paymentMode   PaymentMode
  reference     String?
  notes         String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  party Party @relation(fields: [partyId], references: [id])

  @@unique([tenantId, paymentNumber])
  @@map("payments")
}

model Receipt {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  partyId       String
  accountId     String
  receiptNumber String
  receiptDate   DateTime
  amount        Decimal     @db.Decimal(18, 4)
  paymentMode   PaymentMode
  reference     String?
  notes         String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  party Party @relation(fields: [partyId], references: [id])

  @@unique([tenantId, receiptNumber])
  @@map("receipts")
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  CARD
  OTHER
}

model PDCCheque {
  id           String     @id @default(cuid())
  tenantId     String
  partyId      String
  branchId     String
  chequeType   ChequeType
  amount       Decimal    @db.Decimal(18, 4)
  bankName     String?
  chequeNumber String
  maturityDate DateTime
  status       PDCStatus  @default(PENDING)
  isBounced    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  party Party @relation(fields: [partyId], references: [id])

  @@unique([tenantId, chequeNumber])
  @@map("pdc_cheques")
}

enum ChequeType {
  RECEIVED
  ISSUED
}

enum PDCStatus {
  PENDING
  CLEARED
  BOUNCED
  CANCELLED
}

// ==================== POS ====================

model POSSession {
  id              String        @id @default(cuid())
  tenantId        String
  branchId        String
  userId          String
  openingFloat    Decimal       @db.Decimal(18, 4)
  closingFloat    Decimal?
  openingTime     DateTime      @default(now())
  closingTime     DateTime?
  status          SessionStatus @default(OPEN)
  overShortAmount Decimal?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branch       Branch           @relation(fields: [branchId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  transactions POSTransaction[]

  @@map("pos_sessions")
}

enum SessionStatus {
  OPEN
  CLOSED
}

model POSTransaction {
  id                String               @id @default(cuid())
  tenantId          String
  branchId          String
  sessionId         String
  transactionNumber String
  transactionDate   DateTime             @default(now())
  customerId        String?
  totalAmount       Decimal              @db.Decimal(18, 4)
  totalTax          Decimal              @default(0) @db.Decimal(18, 4)
  discountAmount    Decimal              @default(0) @db.Decimal(18, 4)
  status            POSTransactionStatus @default(COMPLETED)
  isSynced          Boolean              @default(false)
  syncedAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  session        POSSession              @relation(fields: [sessionId], references: [id])
  lines          POSTransactionLine[]
  payments       POSTransactionPayment[]
  returnRequests ReturnRequest[]

  @@unique([tenantId, transactionNumber])
  @@map("pos_transactions")
}

enum POSTransactionStatus {
  COMPLETED
  RETURNED
  CANCELLED
  HELD
}

model POSTransactionLine {
  id              String  @id @default(cuid())
  transactionId   String
  itemId          String
  unitId          String
  quantity        Decimal @db.Decimal(18, 6)
  unitPrice       Decimal @db.Decimal(18, 6)
  discountPercent Decimal @default(0) @db.Decimal(18, 4)
  taxPercent      Decimal @default(0) @db.Decimal(18, 4)
  lineTotal       Decimal @db.Decimal(18, 4)

  transaction POSTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("pos_transaction_lines")
}

model POSTransactionPayment {
  id            String      @id @default(cuid())
  transactionId String
  paymentMode   PaymentMode
  amount        Decimal     @db.Decimal(18, 4)
  reference     String?

  transaction POSTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("pos_transaction_payments")
}

// ==================== APPROVAL ENGINE ====================

model ApprovalChain {
  id              String   @id @default(cuid())
  tenantId        String
  module          String
  action          String
  thresholdAmount Decimal?
  approverRoles   Role[]
  escalationHours Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  requests ApprovalRequest[]

  @@map("approval_chains")
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  chainId        String
  tenantId       String
  referenceType  String
  referenceId    String
  requestedById  String
  status         ApprovalStatus @default(PENDING)
  requestedAt    DateTime       @default(now())
  resolvedAt     DateTime?
  resolutionNote String?

  chain   ApprovalChain    @relation(fields: [chainId], references: [id])
  records ApprovalRecord[]

  @@map("approval_requests")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model ApprovalRecord {
  id         String           @id @default(cuid())
  requestId  String
  approverId String
  decision   ApprovalDecision
  decisionAt DateTime         @default(now())
  notes      String?

  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver  User            @relation(fields: [approverId], references: [id])
  Voucher   Voucher?        @relation(fields: [voucherId], references: [id])
  voucherId String?

  @@map("approval_records")
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

model ReturnRequest {
  id                String       @id @default(cuid())
  tenantId          String
  branchId          String
  posTransactionId  String
  requestById       String
  reasonCode        String
  totalAmount       Decimal      @db.Decimal(18, 4)
  status            ReturnStatus @default(PENDING)
  approvalRequestId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  posTransaction POSTransaction @relation(fields: [posTransactionId], references: [id])

  @@map("return_requests")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

// ==================== PRICING ====================

model PriceList {
  id         String     @id @default(cuid())
  tenantId   String
  name       String
  partyClass PartyClass
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  items   PriceListItem[]
  parties Party[]

  @@unique([tenantId, name])
  @@map("price_lists")
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  itemId      String
  unitId      String
  price       Decimal   @db.Decimal(18, 6)
  minQty      Decimal   @default(0) @db.Decimal(18, 6)
  validFrom   DateTime  @default(now())
  validTo     DateTime?

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([priceListId, itemId, unitId, minQty, validFrom])
  @@map("price_list_items")
}

model Scheme {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  type      SchemeType
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("schemes")
}

enum SchemeType {
  SLAB_DISCOUNT
  BUY_X_GET_Y
  BUNDLE_PRICE
  FLAT_DISCOUNT
}

// ==================== AUDIT & ATTACHMENTS ====================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  entityType  String
  entityId    String
  beforeValue Json?
  afterValue  Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Attachment {
  id           String   @id @default(cuid())
  tenantId     String
  entityType   String
  entityId     String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedById String
  createdAt    DateTime @default(now())
  Voucher      Voucher? @relation(fields: [voucherId], references: [id])
  voucherId    String?

  @@map("attachments")
}
