# Database
# Local example: postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public
# Remote/aaPanel example: postgresql://cosmamtic_user:STRONG_PASSWORD@YOUR_SERVER_IP:5432/cosmamtic_db?schema=public
# Add sslmode=require if your server enforces SSL: ?schema=public&sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cosmamtic?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:2025"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Optional: OAuth providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Email/SMS/WhatsApp
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMS_API_KEY=
# WHATSAPP_API_KEY=

# Optional: S3-compatible storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
